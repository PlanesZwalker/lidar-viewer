# ── Web viewer ────────────────────────────────────────────────────────────────
# Base URL for remote point cloud files (served via nginx /pointclouds/)
VITE_CLOUD_BASE_URL=http://your-server.com/pointclouds

# ── Mobile app ────────────────────────────────────────────────────────────────
# LAN IP of the machine running `pnpm dev` — used by the React Native WebView
EXPO_PUBLIC_VIEWER_URL=http://192.168.1.100:5173

# ── Docker deployment ────────────────────────────────────────────────────────
# Set LOCAL_MODE=true to enable file browsing from the mounted /data directory
LOCAL_MODE=false
HOST_IP=0.0.0.0
